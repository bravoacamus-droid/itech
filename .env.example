# === Supabase (públicas: seguras para el navegador) ===
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"

# === Solo servidor (NUNCA exponer al cliente, NUNCA commitear) ===
# Va únicamente en .env.local de cada app o en variables de entorno de Vercel.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# === CLI / Management (solo local, fuera del repo) ===
SUPABASE_ACCESS_TOKEN="tu-access-token"

# === IA (solo servidor) ===
GEMINI_API_KEY="tu-gemini-api-key"
RESEND_API_KEY="tu-resend-api-key"
RESEND_FROM="iTech <noreply@tudominio.com>"
SUNAT_CERT_PASSWORD="clave-del-certificado"
SUNAT_SOL_PASSWORD="clave-sol"
